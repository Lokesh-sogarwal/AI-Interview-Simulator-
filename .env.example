# MongoDB (optional but recommended for dashboard/history)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=interview_simulator

# Auth
JWT_SECRET=change_me_to_a_long_random_string

# OpenAI (optional; app falls back to mock questions/evals without it)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Hugging Face (optional; preferred over OpenAI when set)
# NOTE: Hugging Face deprecated https://api-inference.huggingface.co — the SDK uses https://router.huggingface.co.
# If you see "model_not_supported" errors, enable at least one Inference Provider for your account in HF settings.
HUGGINGFACE_API_KEY=


HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3


HUGGINGFACE_PROVIDER=


HUGGINGFACE_MODEL_RESUME=mistralai/Mistral-7B-Instruct-v0.3
HUGGINGFACE_MODEL_QUESTION=mistralai/Mistral‑7B‑Instruct v0.3
HUGGINGFACE_MODEL_EVAL=mistralai/Mixtral‑8x7B‑Instruct-v0.1

# Optional: allow saving interviews without signing in.
# Defaults to enabled in development and disabled in production.
ALLOW_ANON_INTERVIEWS=false